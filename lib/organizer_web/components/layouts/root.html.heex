<!DOCTYPE html>
<html lang="pt-BR" data-theme="organizer_softlight">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Organizer" suffix="">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link phx-track-static rel="icon" type="image/x-icon" href={~p"/favicon.svg"} />
    <link phx-track-static rel="shortcut icon" type="image/x-icon" href={~p"/favicon.svg"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="min-h-screen text-base-content">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-3 focus:top-3 focus:z-50 focus:rounded-md focus:bg-base-100 focus:px-3 focus:py-2 focus:text-sm focus:font-medium"
    >
      Pular para o conteudo principal
    </a>

    <nav
      aria-label="Navegação da conta"
      class={[
        "site-nav relative z-20 border-b border-base-300/60 bg-base-100/70 backdrop-blur",
        !@current_scope && "public-guest-nav"
      ]}
    >
      <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-x-3 gap-y-2 px-4 py-3 sm:flex-nowrap sm:px-6 lg:px-8 2xl:max-w-[100rem]">
        <.link href={~p"/"} class="inline-flex min-w-0 items-center gap-2.5">
          <img src={~p"/images/organizer-logo.svg"} alt="Organizer" class="brand-mark h-8 w-8" />
          <span class="brand-wordmark hidden text-xs font-semibold uppercase tracking-[0.2em] min-[360px]:inline">
            Organizer
          </span>
        </.link>

        <ul class={[
          "menu nav-menu menu-horizontal flex-wrap justify-end gap-1 p-0",
          !@current_scope && "public-guest-menu"
        ]}>
          <%= if @current_scope do %>
            <li>
              <.link href={~p"/finances"} class="top-nav-link">Finanças</.link>
            </li>
            <li>
              <.link href={~p"/tasks"} class="top-nav-link">Tarefas</.link>
            </li>
            <li>
              <.link href={~p"/account-links"} class="top-nav-link">Compartilhamentos</.link>
            </li>
            <li>
              <.link href={~p"/users/settings"} class="top-nav-link">Configuração</.link>
            </li>
            <li>
              <.link href={~p"/users/log-out"} method="delete" class="top-nav-link">Sair</.link>
            </li>
          <% else %>
            <li>
              <.link href={~p"/users/register"} class="top-nav-link public-guest-link">
                Criar conta
              </.link>
            </li>
            <li>
              <.link href={~p"/users/log-in"} class="top-nav-link public-guest-link">
                Entrar
              </.link>
            </li>
          <% end %>
        </ul>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
